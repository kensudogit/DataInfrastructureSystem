# Local development
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Database (PostgreSQL local)
DATABASE_URL=postgresql+psycopg2://adinfra:adinfra@localhost:5433/adinfra

# Warehouse target: postgres | snowflake | bigquery | redshift
WAREHOUSE_TARGET=postgres

# Object storage / landing (local path or s3/gcs/azure URI)
LANDING_PATH=./data/landing
CURATED_PATH=./data/curated

# Use mock collectors when API keys are missing
COLLECTOR_USE_MOCK=true

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Yahoo! Ads
YAHOO_ADS_APP_ID=
YAHOO_ADS_SECRET=
YAHOO_ADS_REFRESH_TOKEN=

# Meta (Facebook / Instagram)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_APP_ID=
META_APP_SECRET=

# X (Twitter)
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# LINE Ads
LINE_ADS_ACCESS_KEY=
LINE_ADS_SECRET_KEY=

# TikTok Ads
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# AI providers
AI_PROVIDER=openai
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AWS_BEDROCK_REGION=ap-northeast-1
GCP_VERTEX_PROJECT=
GCP_VERTEX_LOCATION=asia-northeast1

# Cloud warehouse (optional)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=AD_INFRA
SNOWFLAKE_SCHEMA=MART

BIGQUERY_PROJECT=
BIGQUERY_DATASET=ad_infra

REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_DB=adinfra
REDSHIFT_USER=
REDSHIFT_PASSWORD=
